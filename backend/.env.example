# Copy this file to .env and fill in your values

# Port the backend server listens on
PORT=4000

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/chatapp

# Secret key used to sign JWT tokens — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# URL of the frontend — used by CORS to allow browser requests
CLIENT_URL=http://localhost:3000
